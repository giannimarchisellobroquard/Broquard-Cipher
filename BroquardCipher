# Detect package manager
PKG_MANAGER=""
if   [ $IS_TERMUX -eq 1 ];               then PKG_MANAGER="pkg"
elif command -v apt-get  >/dev/null 2>&1; then PKG_MANAGER="apt-get"
elif command -v dnf      >/dev/null 2>&1; then PKG_MANAGER="dnf"
