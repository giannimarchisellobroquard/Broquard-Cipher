#   sh install.sh --force   # reinstall everything
#
# Supported:
#   Linux   — Debian/Ubuntu, Fedora/RHEL, Arch, Alpine, openSUSE, Void, Nix
#   macOS   — Homebrew (auto-installs if missing)
