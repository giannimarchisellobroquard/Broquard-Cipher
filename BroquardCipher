        print("    Fedora:         sudo dnf install python3.12")
        print("    Arch:           sudo pacman -S python")
        print("    Alpine:         sudo apk add python3")
        print("    Termux:         pkg install python")
        print("    or: https://www.python.org/downloads/")
    print()
    sys.exit(1)

